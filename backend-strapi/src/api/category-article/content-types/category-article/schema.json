{
  "kind": "collectionType",
  "collectionName": "category_articles",
  "info": {
    "singularName": "category-article",
    "pluralName": "category-articles",
    "displayName": "CategoryArticle"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "category_articles"
    }
  }
}
