{
  "kind": "collectionType",
  "collectionName": "authorities",
  "info": {
    "singularName": "authority",
    "pluralName": "authorities",
    "displayName": "Authority"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "type": "string",
      "required": true
    },
    "profession": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "area": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::area.area"
    },
    "description": {
      "type": "blocks"
    },
    "contactLinks": {
      "type": "component",
      "component": "shared.link",
      "repeatable": true
    }
  }
}
