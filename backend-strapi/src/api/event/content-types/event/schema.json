{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "date": {
      "type": "datetime"
    },
    "endDate": {
      "type": "datetime"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "locationName": {
      "type": "string"
    },
    "locationUrl": {
      "type": "string"
    },
    "isRecurring": {
      "type": "boolean",
      "default": false
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.content",
        "shared.gallery",
        "shared.link",
        "shared.youtube"
      ]
    },
    "category_events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category-event.category-event",
      "mappedBy": "events"
    }
  }
}
