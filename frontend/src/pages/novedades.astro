---
import HeaderPage from "../components/HeaderPage.astro";
import Layout from "../layouts/Layout.astro";
import CardArticle from "../components/CardArticle.astro";

const API_ARTICLES = import.meta.env.API_ARTICLES;

const PAGE_SIZE = 9;

const res = await fetch(`${API_ARTICLES}/api/articles?pagination[page]=1&pagination[pageSize]=${PAGE_SIZE}`);
const json = await res.json();

const articles = json.data;

const totalArticles = json.meta.pagination.total;
console.log(totalArticles);
---

<Layout title="Novedades" description="Novedades de Colegio Público de Ingenieros de Formosa">
    <HeaderPage 
     title="Novedades" 
     slug="novedades" 
     cover="https://res.cloudinary.com/du86bx5o0/image/upload/v1773192769/Gemini_Generated_Image_kfx8l5kfx8l5kfx8_4f63abf5e8.png"
    />
    <section class="md:pt-20 container mx-auto px-4 py-20">
        <h1 class="text-4xl font-bold text-green-950 text-center mb-8">Todas las Novedades</h1>
        <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
           {
            articles.map((article: any) => (
              <CardArticle
                title={article.title}
                description={article.description}
                image={article.cover}
                slug={article.slug}
                category={article.category || "Novedades"}
                date={article.created_at}
              />
            ))
           }
        </div>

            <!-- BOTÓN VER MÁS -->
        <div class="container mx-auto flex justify-center flex-col gap-4 items-center mt-10">
          <span class="text-sm text-gray-500">Mostrando {articles.length} de {totalArticles} novedades</span>
          <button 
            id="load-more-btn"
            class="w-fit bg-green-700 border-2 border-green-200 text-white p-2 px-4 rounded-full hover:bg-green-600
             transition-colors cursor-pointer animate-rubber-band">
            Mostrar más novedades
          </button>
        </div>

        <!-- Trigger -->
        <div id="load-more-trigger" class="h-10"></div>

        <!-- Loader -->
        <div id="loader" class="text-center py-6 hidden">
          <p class="animate-pulse text-gray-500">Cargando más novedades...</p>
        </div>
    </section>
</Layout>

<script>

    let page = 1;
    let loading = false;
    let hasMore = true;
    let infiniteEnabled = false;

    const PAGE_SIZE = 9;
    const API_URL = "https://colegio-ingeniero-api.vercel.app/api/articles";

    const cache = new Map();

    const container = document.getElementById("articles-grid") as HTMLDivElement;
    const trigger = document.getElementById("load-more-trigger") as HTMLDivElement;
    const loader = document.getElementById("loader") as HTMLDivElement;
    const button = document.getElementById("load-more-btn") as HTMLButtonElement;

   const formatDate = (date: string) => {
      const options: Intl.DateTimeFormatOptions = {
        day: "numeric",
        month: "long",
        year: "numeric",
      };
      return new Date(date).toLocaleDateString("es", options);
    };


    function createCard(article: any) {
      
      const el = document.createElement("article");
      el.className = "bg-gray-100 rounded-2xl overflow-hidden p-4 border-2 border-gray-300 hover:border-green-600 transition-colors relative";
      
      const link = `/post/${article.slug}`;
      const imageHtml = article.cover
        ? `<img class="w-full h-48 rounded-xl object-cover cursor-pointer" src="${article.cover}" alt="${article.title}" />`
        : `<div class="w-full h-48 rounded-xl bg-gray-300 flex items-center justify-center"><span class="text-gray-500 text-sm">Sin imagen</span></div>`;


      el.innerHTML = `
       <a href=${link}>
          ${imageHtml}
       </a>

       <span class="text-sm w-fit not-prose bg-green-800 text-white px-4 py-1
         rounded-xl absolute top-6 left-6">${article.category}</span>

       <div class="p-4 pb-0 prose flex flex-col min-h-47">
          <h3 class="text-lg font-bold line-clamp-2">${article.title}</h3>
          <p class="text-sm text-gray-600 line-clamp-3">
            ${article.description}
          </p>
          <div class="flex justify-between items-center mt-auto">
            <span class="text-sm text-gray-400">${formatDate(article.created_at)}</span>
            <a href=${link}
              class="bg-gray-300 text-white p-2 rounded-full flex items-center
              hover:bg-green-700 transition-colors" title="Leer más">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4"> <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"></path> </svg>
            </a>
          </div>
       </div>
      `;

      return el;
    }

    async function getArticles(page: number) {
      if (cache.has(page)) return cache.get(page);

      const res = await fetch(
        `${API_URL}?pagination[page]=${page}&pagination[pageSize]=${PAGE_SIZE}`,
        { cache: "force-cache" }
      );

      const data = await res.json();
      cache.set(page, data);
      return data;
    }

    async function loadNextPage() {
      if (loading || !hasMore) return;

      loading = true;
      loader.classList.remove("hidden");

      page++;

      const data = await getArticles(page);

      if (!data.data || data.data.length === 0) {
        hasMore = false;
        loader.innerText = "No hay más novedades";
        return;
      }

      const fragment = document.createDocumentFragment();

      data.data.forEach((article: any) => {
        fragment.appendChild(createCard(article));
      });

      container.appendChild(fragment);

      loader.classList.add("hidden");
      loading = false;
    }

    // 👉 CLICK INICIAL
    button.addEventListener("click", async () => {
      button.style.display = "none";

      await loadNextPage();

      // activar infinite scroll
      infiniteEnabled = true;
      observer.observe(trigger);
    });

    // 👉 INFINITE SCROLL
    const observer = new IntersectionObserver(async (entries) => {
      if (!entries[0].isIntersecting || !infiniteEnabled) return;

      await loadNextPage();
    });
</script>