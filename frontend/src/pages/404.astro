---
import ArrowRightIcon from "../components/icons/ArrowRightIcon.astro"
import Layout from "../layouts/Layout.astro"
---

<Layout title="404" description="404">
     <section class="container mx-auto px-4 py-20 flex flex-col gap-2 items-center justify-center">
          <h1 class="text-9xl font-bold text-green-600">404</h1>
           <h2 class="text-3xl text-green-950 mb-4">Página no encontrada</h2>
           <p class="text-lg text-gray-600">Lo sentimos, la pagina que buscas no existe o ha sido movida. 
          Verifica la URL</p>
           <a class="bg-green-600 text-white px-4 py-2 rounded-full flex items-center mt-4" href="/">
             <span>Volver al inicio</span>
             <ArrowRightIcon class="h-6 w-6 ml-2" /> 
          </a>
     </section>
</Layout>