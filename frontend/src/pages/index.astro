---
import Layout from "../layouts/Layout.astro";
import { getAllPages, getHomePage } from "../lib/strapi";
import { YouTube } from '@astro-community/astro-embed-youtube';
import Slider from "../components/HeroSlider.astro";
import LinkCta from "../components/LinkCta.astro";
import ArrowRightIcon from "../components/icons/ArrowRightIcon.astro";
import FeaturedArticles from "../components/FeaturedArticles.astro";
import ResolutionItem from "../components/ResolutionItem.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import SectionResolution from "../components/SectionResolution.astro";
import AdOverlay from "../components/AdOverlay.astro";
import FeaturedCourses from "../components/FeaturedCourses.astro";
import FeaturedAuthorities from "../components/FeaturedAuthorities.astro";
import InstructionalVideos from "../components/InstructionalVideos.astro";
import FeaturedDocuments from "../components/FeaturedDocuments.astro";
import FeaturedContent from "../components/FeaturedContent.astro";
import SectionInstagram from "../components/SectionInstagram.astro";

const findBlock = (page: any, block: string) => {
  return page.blocks.find(
    (blck: any) => blck.__component === `blocks.${block}`,
  ) || null;
}

const infoPage = await getHomePage();

const heroSlider = findBlock(infoPage, "slider");
const featuredArticles = findBlock(infoPage, "featured-articles");
const legalDocuments = findBlock(infoPage, "legal-documents");
const featuredAuthorities = findBlock(infoPage, "featured-authorities");
const featuredDocuments = findBlock(infoPage, "featured-documents");
const adOverlayData = findBlock(infoPage, "ad-overlay");
const featuredCourses = findBlock(infoPage, "featured-courses");
const instructionalVideos = findBlock(infoPage, "instructional-videos");
const featuredContent = findBlock(infoPage, "featured-content");

---

<Layout title={infoPage.title}>
  
  <AdOverlay data={adOverlayData} /> 
  <Slider data={heroSlider} />

  <main class="bg-gray-200/90">
     
    <FeaturedContent data={featuredContent} /> 
    <SectionResolution data={legalDocuments} />
    <InstructionalVideos data={instructionalVideos} />  
    <FeaturedAuthorities data={featuredAuthorities} /> 
    <FeaturedDocuments data={featuredDocuments} /> 
    <FeaturedArticles data={featuredArticles} />
    <SectionInstagram />
    <FeaturedCourses data={featuredCourses} />

  </main>
</Layout>
