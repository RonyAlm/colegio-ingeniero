---
import { getAllEvents } from "../lib/strapi";
import CardEvents from "./CardEvents.astro";
import HeadingText from "./HeadingText.astro";
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";
import LinkCta from "./LinkCta.astro";

// Obtener eventos
const events = await getAllEvents();

// Fecha actual
const now = new Date();

// Filtrar eventos próximos o en curso
const upcomingEvents = events.filter((event: any) => {

  const startDate =
    new Date(event.date);

  const endDate =
    event.endDate
      ? new Date(event.endDate)
      : startDate;

  // Mostrar:
  // - eventos futuros
  // - eventos en curso
  return endDate >= now;
});

// Ordenar por fecha más cercana
upcomingEvents.sort(
  (a: any, b: any) =>
    new Date(a.date).getTime() -
    new Date(b.date).getTime()
);

// Limitar a 6 eventos
const featuredEvents =
  upcomingEvents.slice(0, 6);
---

<section class=" px-4 py-20 bg-linear-to-t from-green-600 to-green-800">

  <div class="container mx-auto px-4">

    <!-- HEADER -->
    <div class="flex flex-col items-center text-center mb-10">
      <span class="text-sm uppercase tracking-widest text-green-500 font-semibold mb-4">
        Agenda de Eventos
      </span>
      <HeadingText title={`Próximos eventos`} description={`
       Descubrí las próximas capacitaciones,
        conferencias y actividades que están
        por comenzar o se encuentran en curso.
      `}  />
    </div>

    <!-- GRID -->
    {
      featuredEvents.length > 0 ? (

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

          {featuredEvents.map((event: any) => (
            <CardEvents event={event} />
          ))}

        </div>

      ) : (

        <div class="bg-white rounded-2xl shadow p-10 text-center">

          <h3 class="text-2xl font-semibold text-gray-700">
            No hay próximos eventos
          </h3>

          <p class="text-gray-500 mt-2">
            Próximamente se agregarán nuevas actividades.
          </p>

        </div>

      )
    }

    <div class="flex items-center justify-center mt-10">
      <LinkCta href="/eventos" type="TERTIARY" label="Ver todos los eventos">
        <ArrowRightIcon class="h-6 w-6 ml-2" />
      </LinkCta>
    </div>

  </div>

</section>