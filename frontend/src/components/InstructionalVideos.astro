---
import { YouTube } from "@astro-community/astro-embed-youtube"
import ArrowRightIcon from "../components/icons/ArrowRightIcon.astro"
import LinkCta from "../components/LinkCta.astro"

const { title, description, cta, videos} = Astro.props;
---
   
   <section class="md:pt-20 container mx-auto px-4 py-20">
      <h2 class="text-4xl text-green-950 text-center mb-12">
        { title.split(" ")[0]  } <span class="text-green-600 font-bold">{title.split(" ")[1]}</span> 
      </h2>
      {
        description && (
          <p class="text-center text-sm md:text-base text-green-950/50 opacity-80 mb-4">
            {description}
          </p>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            videos.map((video: any) => (
              <YouTube id={video.videoId} class="aspect-video mx-auto w-full rounded-2xl" 
              title={video.title} />
            ))
          }
      </div>
      <div class="flex items-center justify-center mt-10">
        {
          cta && (
            cta.map(({ href, label } : any) => (
              <LinkCta href={href} type="QUATERNARY" label={label}>
                <ArrowRightIcon class="h-6 w-6 ml-2" />
              </LinkCta>
            ))
          )
        }
      </div>
    </section>