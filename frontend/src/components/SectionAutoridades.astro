---
import CardAutoridad from "./CardAutoridad.astro";
import DocumentIcon from "./icons/DocumentIcon.astro";
import IconUsers from "./icons/IconUsers.astro";
import ScaleIcon from "./icons/ScaleIcon.astro";
import IconShieldCheck from "./icons/IconShieldCheck.astro";
const { data } = Astro.props;
const { title, description, iconSection, autoridadesComponent } = data;

const autoridades = autoridadesComponent.map(
  (autoridad: any) => autoridad,
);

const iconSectionAutoridades: Record<string, any> = {
  Users: IconUsers,
  ScaleIcon: ScaleIcon,
  ShieldCheck: IconShieldCheck,
}

const Icon = iconSectionAutoridades[iconSection] || DocumentIcon

---

<section class="container mx-auto px-4 py-10 md:py-10">
  <div class="flex items-center mb-6 justify-center">
    <div
       class="flex items-center justify-center w-15 h-15 p-4 rounded-full bg-green-600/10">
       { <Icon class="w-6 h-6 text-green-700" /> }
    </div>
    <div class="ml-4">
      <h3 class="text-xl md:text-3xl text-green-700">
        {title}
      </h3>
      <p class="hidden md:block text-sm text-gray-400">{description}</p>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-2">
    {
      autoridades.map((autoridad: any) => (
        <CardAutoridad autoridad={autoridad} type="secondary" />
      ))
    }
  </div>
</section>
