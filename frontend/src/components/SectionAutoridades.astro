---
import CardAutoridad from "./CardAutoridad.astro";
const { data } = Astro.props;
// console.log(data);

const autoridades = data.autoridadesComponent.map(
  (autoridad: any) => autoridad,
);
// console.log(autoridades);
---

<section class="container mx-auto px-4 py-10 md:py-20">
  <h3 class="text-2xl  md:text-3xl text-green-700 text-center mb-2 uppercase">
    {data.title}
  </h3>
  <p class="text-lg">{data.description}</p>
  <hr class="border-green-700 w-1/12 mx-auto mb-6">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-2">
    {
      autoridades.map((autoridad: any) => (
        <CardAutoridad autoridad={autoridad} type="secondary" />
      ))
    }
  </div>
</section>
