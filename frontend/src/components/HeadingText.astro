---
interface Props {
  title: string;
  description?: string;
  variant?: "white" | "green";
}
const { title, description, variant = "white" } = Astro.props as Props;
---

<div class="container mx-auto px-4 py-10">
  <h2 class={  `${variant === "white" ? "text-green-100" : "text-green-950"} text-4xl text-center`}>
    {title.split(" ")[0]}
    <span class={`${variant === "green" ? "text-green-600" : "text-green-100"} font-bold inline-block relative`}>
      {title.split(" ").slice(1).join(" ")}
      <span class="absolute left-0 -bottom-5 w-full z-[-1]">
        <svg viewBox="0 0 200 20" class="w-full">
          <path
            d="M0 10 Q50 20 100 10 T200 10"
            stroke="currentColor"
            stroke-width="4"
            fill="none"
            stroke-linecap="round"></path>
        </svg>
      </span>
    </span>
  </h2>
  {
    description && (
      <p class={`${variant === "white" ? "text-green-100" : "text-green-950/50"} text-center text-sm md:text-base opacity-80 mt-4`}>
        {description}
      </p>
    )
  }
</div>
