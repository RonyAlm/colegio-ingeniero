---
 import { getPostsPage } from "../lib/strapi";
 import CardArticle from "./CardArticle.astro";
 import LinkCta from "./LinkCta.astro";
 import ArrowRightIcon from "./icons/ArrowRightIcon.astro";

 const { data } = await getPostsPage(1, 3);
 const recentArticles  = data;
   
---

 <section class="container mx-auto py-10 pb-20 px-8 md:px-0">
    <div class="flex flex-col items-center py-10">
      <h2 class="text-2xl md:text-4xl text-center text-green-950 mb-6 md:mb-0">
        Noticias y <strong class="font-bold text-green-600">Novedades</strong> 
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        recentArticles.map((post: any) => (
          <CardArticle
             {...post}
          />
        ))
      }
    </div>
  </section>