---
import ArrowTop from "../components/icons/ArrowTop.astro";
import CalendarIcon from "./icons/CalendarIcon.astro";
import DocumentIcon from "./icons/DocumentIcon.astro";
import EyeIcon from "./icons/EyeIcon.astro";
import DownIcon from "./icons/DownIcon.astro";
import LinkCta from "./LinkCta.astro";
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";

const { title, description, slug, categories, publishedAt, linkDownload } = Astro.props;

const date = new Date(publishedAt).toLocaleDateString("es-AR", {
    day: "numeric",
    month: "long",
    year: "numeric",
});

const linkDetail =  linkDownload && linkDownload.includes(".pdf") ? `/document/${slug}` : `/docs/${linkDownload}`;


---

<article
  class="bg-gray-100 rounded-2xl border-2 border-transparent hover:border-green-600 hover:shadow transition-all duration-300 
  flex justify-between flex-col h-full ">
  <a href={linkDetail} class="p-6 flex flex-col gap-2">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-3">
        <div
          class="flex items-center justify-center w-10 h-10 p-2 rounded-lg bg-green-600/10">
          <DocumentIcon class="w-5 h-5 text-primary" />
        </div>
        <div class="flex items-center flex-wrap gap-2">
          { 
            categories.map((category: any) => (
              <span class="bg-green-600/10 text-green-950/80 px-3 py-1 rounded-lg text-sm">
                {category.name}
              </span> 
            ))
          }          
        </div>
      </div>
    </div>
    <h3 class="text-lg font-semibold text-card-foreground mt-3 line-clamp-2">
      {title}
    </h3>
    <p class="text-gray-700 text-sm line-clamp-2 mb-4">
      {description}
    </p>
    <div class="flex items-center gap-2 text-gray-600 text-sm">
      <CalendarIcon class="w-4 h-4" />
      <span>{date}</span>
    </div>
  </a>

  <div class="py-4 border-t border-gray-200 flex items-center justify-around gap-3">
     <LinkCta href={linkDetail} type="QUATERNARY" label="Ver Detalle">
       <EyeIcon class="h-6 w-6 ml-2" />
     </LinkCta>
     <LinkCta href={`/docs/${linkDownload}`} type="PRIMARY" label="Descargar" isDownload>
       <DownIcon class="h-6 w-6 ml-2" />
     </LinkCta>
  </div>
</article>
