---
import LinkCta from "./LinkCta.astro";
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";
const { title, description, link } = Astro.props;
---

<section class="container mx-auto px-4 py-10 md:py-20 flex flex-col items-center">
  <h3 class="text-2xl font-bold md:text-4xl text-green-700 mb-4 uppercase">
    {title}
  </h3>
   {
    description && (
      <p class="text-lg text-green-950/70 max-w-3xl text-center">{description}</p>
   )}
  {
    link && (
      <div class="flex items-center mt-6">
        
          <LinkCta href={link.href} type="QUATERNARY" label={link.label}>
            <ArrowRightIcon class="h-6 w-6 ml-2" />
          </LinkCta>
        
      </div>
    )
  }
</section>
