---
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";
import DocumentIcon from "./icons/DocumentIcon.astro";
import DownIcon from "./icons/DownIcon.astro";
import LinkCta from "./LinkCta.astro";

const { slug, title , description, publishedAt, document, category } = Astro.props;
const date = new Date(publishedAt).toLocaleDateString("es-AR")

---

<article class="bg-green-700 rounded-2xl py-8 px-6 shadow flex gap-4 items-center md:justify-center justify-between">
  <a href={"/document/" + slug}>
    <DocumentIcon class="h-18 w-18 text-gray-200 hover:text-white hover:scale-105 transition-transform" />
  </a>
  <a class="flex flex-col"
    href={"/document/" + slug}>
    <h3 class="text-xl font-bold text-white uppercase">
        {title}
    </h3>
    <span class="text-sm text-gray-200">{date}</span>
    <div class="hidden md:flex gap-4 justify-center items-center">
      <LinkCta href={"/document/" + slug} label="Ver">
        <ArrowRightIcon class="h-6 w-6 ml-2" />
      </LinkCta>
      <LinkCta
        href={`/docs/${slug}.pdf`}
        type="TERTIARY"
        isDownload
        isExternal
        label="Descargar">
        <DownIcon class="h-6 w-6 ml-2" />
      </LinkCta>
    </div>
    <div class="flex flex-col md:hidden gap-4 justify-center items-center">
      <LinkCta
        href={`/docs/${slug}.pdf`}
        type="TERTIARY"
        isDownload
        isExternal>
        <DownIcon class="h-6 w-6" />
      </LinkCta>
       <LinkCta
        href={"/document/" + slug}
        type="TERTIARY">
        <ArrowRightIcon class="h-6 w-6" />
      </LinkCta>
    </div>
  </a>

</article>
