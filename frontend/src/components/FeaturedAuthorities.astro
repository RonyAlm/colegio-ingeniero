---
import CardAuthority from "./CardAuthority.astro";
import HeadingText from "./HeadingText.astro";
import LinkCta from "./LinkCta.astro";
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";

const { title, description, cta, authorities} = Astro.props;

---

<section id="featured-authorities" class="px-4 py-20 bg-linear-to-t from-green-600 to-green-800">
  <div class="container mx-auto h-fit">
    <HeadingText title={title} description={description} variant="white" />
    <!-- <hr class="border-green-100 w-1/12 mx-auto mb-6" /> -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-2">
      {
        authorities.map((autoridad: any) => (
          <CardAuthority data={autoridad} type="primary" />
        ))
      }
    </div>
    {
      cta && (
        <div class="flex items-center justify-center mt-10">
          { 
           cta.map(({ href, label } : any) => (
            <LinkCta href={href} type="TERTIARY" label={label}>
                <ArrowRightIcon class="h-6 w-6 ml-2" />
            </LinkCta>     
           ))
          }
        </div>
      )
    }
  </div>
</section>
