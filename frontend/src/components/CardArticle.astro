---
import ArrowTop from "../components/icons/ArrowTop.astro";

const { cover, title, description, slug, category_articles, publishedAt } = Astro.props;
const link = `/post/${slug}`

const categories = category_articles && category_articles.length ? category_articles : [{ name: "Novedades" }];

const dateString = new Date(publishedAt).toLocaleDateString("es-AR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

---

<article
  class="bg-gray-100 rounded-2xl overflow-hidden p-4
   border-2 border-gray-300 hover:border-green-600 transition-colors relative">

  <a href={link}>
    { cover ? (
      <img
        class="w-full h-48 rounded-xl object-cover cursor-pointer"
        src={cover.url}
        alt={title}
      />
    ) : (
      <div class="w-full h-48 rounded-xl bg-gray-300 flex items-center justify-center">
        <span class="text-gray-500 text-sm">Sin imagen</span>
      </div>
    )}
  </a>
  
  {
    categories.map((category: any) => (
      <span class="text-sm w-fit not-prose bg-green-800 text-white px-4 py-1
        rounded-xl absolute top-6 left-6">{category.name}</span>
    )) 
  }
 
  <div class="p-4 pb-0 prose flex flex-col min-h-47">
    <h3 class="text-lg font-bold line-clamp-2">{title}</h3>
    <p class="text-sm text-gray-600 line-clamp-3">
      {description}
    </p>
    <div class="flex justify-between items-center mt-auto">
      <span class="text-sm text-gray-400">{dateString}</span>
      <a href={link} 
        class="bg-gray-300 text-white p-2 rounded-full flex items-center
        hover:bg-green-700 transition-colors" title="Leer más">
        <ArrowTop class="h-4 w-4" />
      </a>
    </div>
  </div>
   
</article>
