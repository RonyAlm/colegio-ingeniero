---
import ResolutionItem from "./ResolutionItem.astro";
import LinkCta from "./LinkCta.astro";
import ArrowRightIcon from "./icons/ArrowRightIcon.astro";

const { title, description, cta, docs } = Astro.props;
---

<section id="featured-documents" class="md:pt-20 container mx-auto px-4 py-20">
  <h2 class="text-4xl text-green-950 text-center mb-6 mt-8">
    { title.split(" ")[0] }
    <span class="text-green-600 font-bold inline-block relative">
      { title.split(" ")[1] }
      <span class="absolute left-0 -bottom-5 w-full z-[-1]">
        <svg viewBox="0 0 200 20" class="w-full">
          <path 
            d="M0 10 Q50 20 100 10 T200 10" 
            stroke="currentColor" 
            stroke-width="4" 
            fill="none" 
            stroke-linecap="round"
          />
        </svg>
      </span>
    </span>
  </h2>
  {
    description && (
      <p class="text-center text-sm md:text-base text-green-950/50 opacity-80 mb-4">
        {description}
      </p>
    )
  }
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">
    {docs.map((doc: any) => <ResolutionItem data={doc} type="SECONDARY" />)}
  </div>
  {
    cta && (
      <div class="flex items-center justify-center mt-10">
        {cta.map(({ href, label, isExternal }: any) => (
          <LinkCta href={href} type="QUATERNARY" label={label} isExternal={isExternal} >
            <ArrowRightIcon class="h-6 w-6 ml-2" />
          </LinkCta>
        ))}
      </div>
    )
  }
</section>
