{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "richtext"
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "hours": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "links": {
      "type": "component",
      "component": "component.link",
      "repeatable": true
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.youtube",
        "shared.gallery",
        "shared.media"
      ]
    }
  }
}
