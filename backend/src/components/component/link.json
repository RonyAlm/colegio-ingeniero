{
  "collectionName": "components_component_links",
  "info": {
    "displayName": "Link",
    "icon": "apps"
  },
  "options": {},
  "attributes": {
    "href": {
      "type": "string",
      "default": "#",
      "required": false
    },
    "label": {
      "type": "string"
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "isButtonLink": {
      "type": "boolean",
      "default": false
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "PRIMARY",
        "SECONDARY"
      ]
    },
    "isSubmenu": {
      "type": "boolean",
      "default": false
    },
    "submenu": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "isSubmenu"
            },
            true
          ]
        }
      },
      "component": "shared.sub-item",
      "repeatable": true
    }
  },
  "config": {}
}
